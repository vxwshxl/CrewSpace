{
  "manifest_version": 3,
  "name": "CrewAgent",
  "version": "1.0.0",
  "description": "CrewAgent Browser Assistant",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "action": {
    "default_title": "Open CrewAgent Assistant",
    "default_icon": {
      "16": "logoCS.png",
      "32": "logoCS.png",
      "48": "logoCS.png",
      "128": "logoCS.png"
    }
  },
  "icons": {
    "16": "logoCS.png",
    "32": "logoCS.png",
    "48": "logoCS.png",
    "128": "logoCS.png"
  },
  "side_panel": {
    "default_path": "sidebar.html"
  }
}